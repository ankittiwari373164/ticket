{
  "version": 2,
  "buildCommand": "npm ci",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "env": {
    "PORT": "3000",
    "NODE_ENV": "production",
    "EAZY_BASE_URL": "https://help.eazybusiness.in"
  }
}